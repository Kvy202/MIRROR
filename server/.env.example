# Copy this file to server/.env and adjust as needed.

# Port the API + Socket.io server listens on (distinct from sibling projects).
PORT=4001

# MongoDB connection string.
#   Local:  mongodb://127.0.0.1:27017/mirror
#   Atlas:  mongodb+srv://<user>:<pass>@<cluster>/mirror
MONGO_URI=mongodb://127.0.0.1:27017/mirror

# Origin allowed to connect (the Vite client).
CLIENT_ORIGIN=http://localhost:5174

# Secret used to sign session cookies. MUST be set to a long random value in
# production (e.g. `openssl rand -base64 48`).
SESSION_SECRET=mirror-dev-secret-change-me

# Max answers one IP may cast per round (anti-stuffing ceiling).
MAX_VOTES_PER_IP=5

# Ambient reflections (bots) keep the mirror alive when few/no humans are around.
# Set BOTS_ENABLED=false to disable them entirely.
BOTS_ENABLED=true
BOTS_MIN=4
BOTS_MAX=22
BOTS_CHURN=3
BOT_POOL=60
